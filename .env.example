# AgentMail environment variables
# Copy to .env in the script directory, or export before running integrate.sh

# ── Required (pick one) ─────────────────────────────────────────

# Path A: existing admin_key
AMAIL_ADMIN_KEY=

# Path B: product activation code (new system)
AMAIL_PRODUCT_CODE=

# ── Gateway URL ─────────────────────────────────────────────────

# amail-gateway URL (auto-detects localhost:38080 by default)
# AMAIL_URL=http://127.0.0.1:38080
# AMAIL_URL=https://amail.token.tm

# ── Domain ──────────────────────────────────────────────────────

# Mail domain (leave empty to select interactively)
# AMAIL_DOMAIN=admin.local

# ── Snapshots ───────────────────────────────────────────────────

# Save raw email snapshots locally (yes/no, default yes)
# AMAIL_SAVE_SNAPSHOTS=yes

# ── Manager Address ─────────────────────────────────────────────

# Email address of the human manager for notifications
# AMAIL_MANAGER_ADDRESS=admin@example.com

# ── Webhook Mode ────────────────────────────────────────────────

# Webhook routing mode (bridge / internal / direct, default bridge)
# AMAIL_WEBHOOK_MODE=bridge

# Webhook bridge address (ip:port, skips mode prompt when set)
# AMAIL_WEBHOOK_HOST=192.168.1.100:38081

# ── Bridge Binary ───────────────────────────────────────────────

# Override bridge binary path (skips download if exists and executable)
# AMAIL_BRIDGE_BIN=/usr/local/bin/amail-bridge
