# AgentMail 环境变量配置
# 复制为 .env 放在集成脚本同目录下，或 export 后运行 integrate.sh
#
# Copy to .env in the script directory, or export before running integrate.sh

# ── 必填 / Required (选其一 / pick one) ──────────────────────────

# 方式 A：已有 admin_key
# Path A: existing admin_key
AMAIL_ADMIN_KEY=

# 方式 B：产品激活码（新系统）
# Path B: product activation code (new system)
AMAIL_PRODUCT_CODE=

# ── 网关地址 / Gateway URL ──────────────────────────────────────

# amail-gateway 地址（默认自动检测 localhost:38080）
# amail-gateway URL (auto-detects localhost:38080 by default)
# AMAIL_URL=http://127.0.0.1:38080
# AMAIL_URL=https://amail.token.tm

# ── 域名 / Domain ───────────────────────────────────────────────

# 邮件域名（留空则在交互式菜单中选择）
# Mail domain (leave empty to select interactively)
# AMAIL_DOMAIN=admin.local

# ── 快照 / Snapshots ────────────────────────────────────────────

# 是否保存原始邮件快照到本地（yes/no，默认 yes）
# Save raw email snapshots locally (yes/no, default yes)
# AMAIL_SAVE_SNAPSHOTS=yes

# ── 管理员邮箱 / Manager Address ─────────────────────────────────

# 接收通知的管理员邮箱地址
# Email address of the human manager for notifications
# AMAIL_MANAGER_ADDRESS=admin@example.com

# ── Webhook 模式 / Webhook Mode ─────────────────────────────────

# Webhook 路由模式（bridge / internal / direct，默认 bridge）
# Webhook routing mode (bridge / internal / direct, default bridge)
# AMAIL_WEBHOOK_MODE=bridge

# Webhook 地址（ip:port，设置后跳过模式选择）
# Webhook bridge address (ip:port, skips mode prompt when set)
# AMAIL_WEBHOOK_HOST=192.168.1.100:38081

# ── Bridge 版本 / Bridge Version ────────────────────────────────

# amail-bridge 下载版本标签（默认 v0.5.0）
# amail-bridge download version tag (default v0.5.0)
# AMAIL_BRIDGE_VERSION=v0.5.0

# bridge 二进制路径（指定后跳过下载）
# Override bridge binary path (skips download if exists)
# AMAIL_BRIDGE_BIN=/usr/local/bin/amail-bridge

# ── 语言 / Language ─────────────────────────────────────────────

# 集成向导语言（en / zh，默认英语交互式选择）
# Integration wizard language (en / zh, default interactive)
# AMAIL_LANG=en

# ── 高级 / Advanced ─────────────────────────────────────────────

# 覆盖系统 ID（通常由 whoami 自动获取）
# Override system ID (normally auto-detected from whoami)
# AMAIL_SYS_ID=
# AMAIL_TENANT_ID=

# Agent 数据目录覆盖（默认 ~/.agentmail/{email_hash}/）
# Override agent data directory
# AGENTMAIL_HOME=

# 欢迎测试邮件的收件人（默认从配置读取）
# Recipient for welcome test email (default from config)
# MANAGER=925457@qq.com

# 欢迎测试邮件的 Agent email 覆盖
# Override agent email for welcome test
# AGENT_EMAIL=agent@domain.com

# 标题横幅文字
# Banner title text
# TITLE=Agentmail and Hermes Integration Wizard

# 确认卸载（y=跳过确认提示）
# Auto-confirm uninstall (y=skip confirmation prompt)
# CONFIRM=n
