# ──────────────────────────────────────────────────────────────
# amail Hermes Integration — .env template
# Copy to ~/.hermes/.env and fill in your values.
# This file is sourced by integrate.sh for sensitive variables,
# avoiding exposure in process listings (ps aux).
# ──────────────────────────────────────────────────────────────

# Gateway connection
# AMAIL_URL=http://127.0.0.1:38080

# Authentication (choose one):
# AMAIL_ADMIN_KEY=sk-...
# AMAIL_PRODUCT_CODE=amail-...

# Domain configuration
# AMAIL_DOMAIN=admin.local

# Snapshot saving (true/false)
# AMAIL_SAVE_SNAPSHOTS=false

# Default manager email address
# AMAIL_MANAGER_ADDRESS=admin@example.com

# Webhook callback host (for gateway → agent callbacks)
# Leave empty for auto-detection
# AMAIL_WEBHOOK_HOST=

# Local bridge binary path (skip GitHub download)
# AMAIL_BRIDGE_BIN=/usr/local/bin/amail-bridge
