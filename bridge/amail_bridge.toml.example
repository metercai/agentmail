# amail-bridge configuration 
#
# Copy this file to amail_bridge.toml and edit to match your setup.
# hostname = "bridge.internal"         # public address (defaults to addr)

# mode = "push"  # "push" or "pull" (default: "push")

bind = "0.0.0.0:38080"           # Listen address for admin API + push webhooks
# hostname = "bridge.internal"         # public address (defaults to addr)
admin_allowed_ips = ["127.0.0.1", "::1"]   # Admin API IP whitelist

# Logging
# [logging]
# level = "info"                    # log level (default: "info")
# file = "/var/log/amail-bridge.log"  # log file path (default: /var/log/amail-bridge.log)

# ── Pull mode (bridge polls gateway outbound) ───────────────────────
# [pull]
# amail_url = "http://192.168.1.1:38080"  # Gateway HTTP API URL
# admin_key = "sk-..."                    # System admin API key from gateway
# system_id = "admin"                     # System ID for pending-query (default: "admin")
# poll_interval_sec = 10                  # Poll interval in seconds (default: 10)

# ── Forward headers to gateway ──────────────────────────────────
# Headers passed through to the gateway from gateway.
# Single mode: whitelist filter (only listed headers are forwarded).
# Batch mode: listed headers are built from batch entry fields.
# Supported names: x-amail-email, x-webhook-signature, x-mailrelay-timestamp, content-type
# Default: all four amail gateway standard headers
# forward_headers = ["x-amail-email", "x-webhook-signature", "x-mailrelay-timestamp", "content-type"]

# ── Push mode (bridge receives external POSTs) ────────────────────
# [push]
# blacklist_ips = ["1.2.3.4", "10.0.0.0/8"] # permanently blocked IPs/CIDRs (default: [])
# allowed_ips = ["10.0.0.0/8", "192.168.1.1"] # IP allowlist, empty = allow all (default: [])
# rate_limit = 30                            # req/sec per source IP, 0 = disabled (default: 30)
# body_limit_mb = 20                         # max request body size in MB (default: 20)

# Virtual host sites (optional, push mode only)
# [[push.sites]]
# domain = "www.example.com"
# root = "/var/www/example"                  # static site directory
#
# [[push.sites]]
# domain = "api.example.com"
# proxy = "127.0.0.1:3000"                   # reverse proxy target
#
# [[push.sites]]
# domain = "old.example.com"
# redirect = "https://www.example.com"       # 308 redirect URL
